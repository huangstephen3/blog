---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
import { withBase } from '../utils/paths';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="inner">
		<div>
			<p class="site-name">{SITE_TITLE}</p>
			<p class="site-copy">
				&copy; {year} {SITE_AUTHOR}。一个独立运营的 AI 科技新闻站，专注模型、产品、创业与产业信号。
			</p>
		</div>
		<div class="footer-links">
			<a href={withBase('blog/')}>AI快讯</a>
			<a href={withBase('vip/')}>订阅计划</a>
			<a href={withBase('login/')}>读者登录</a>
			<a href={withBase('rss.xml')}>RSS</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding: 3rem 0 4rem;
	}

	.inner {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 1rem;
		width: min(1180px, calc(100% - 1.2rem));
		margin: 0 auto;
		padding-top: 1.4rem;
		border-top: 1px solid rgba(var(--line), 1);
	}

	.site-name {
		margin: 0 0 0.45rem;
		color: rgb(var(--ink));
		font-weight: 800;
	}

	.site-copy {
		margin: 0;
		max-width: 46rem;
		color: rgb(var(--muted));
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
	}

	.footer-links a {
		color: rgb(var(--muted));
		text-decoration: none;
	}

	.footer-links a:hover {
		color: rgb(var(--accent));
	}
</style>
