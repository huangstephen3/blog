---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
import { DEFAULT_LOCALE, getMessages, localePath } from '../lib/i18n';
import { withBase } from '../utils/paths';

interface Props {
	locale?: string;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const messages = getMessages(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="inner">
		<div>
			<p class="site-name">{SITE_TITLE}</p>
			<p class="site-copy">
				&copy; {year} {SITE_AUTHOR}. {messages.footerCopy}
			</p>
		</div>
		<div class="footer-links">
			<a href={withBase(localePath(locale, '/blog/').replace(/^\/+/, ''))}>{messages.footerBriefs}</a>
			<a href={withBase('vip/')}>{messages.nav.membership}</a>
			<a href={withBase('login/')}>{messages.login}</a>
			<a href={withBase('admin/')}>{messages.admin}</a>
			<a href={withBase('rss.xml')}>RSS</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding: 3rem 0 4rem;
	}

	.inner {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 1rem;
		width: min(1180px, calc(100% - 1.2rem));
		margin: 0 auto;
		padding-top: 1.4rem;
		border-top: 1px solid rgba(var(--line), 1);
	}

	.site-name {
		margin: 0 0 0.45rem;
		color: rgb(var(--ink));
		font-weight: 800;
	}

	.site-copy {
		margin: 0;
		max-width: 46rem;
		color: rgb(var(--muted));
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
	}

	.footer-links a {
		color: rgb(var(--muted));
		text-decoration: none;
	}

	.footer-links a:hover {
		color: rgb(var(--accent));
	}
</style>
