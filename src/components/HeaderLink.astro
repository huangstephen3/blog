---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

function normalizePath(path: string) {
	const withoutBase = path.startsWith(import.meta.env.BASE_URL)
		? path.slice(import.meta.env.BASE_URL.length - 1)
		: path;
	const trimmed = withoutBase.endsWith('/') && withoutBase !== '/' ? withoutBase.slice(0, -1) : withoutBase;
	return trimmed || '/';
}

const pathname = normalizePath(Astro.url.pathname);
const target = normalizePath(typeof href === 'string' ? href : '/');
const isActive = target === pathname || (target !== '/' && pathname.startsWith(`${target}/`));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
