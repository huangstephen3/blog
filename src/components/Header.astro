---
import { NAV_LINKS, SITE_TITLE } from '../consts';
import { DEFAULT_LOCALE, getMessages, localePath } from '../lib/i18n';
import HeaderLink from './HeaderLink.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { withBase } from '../utils/paths';

interface Props {
	locale?: string;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const messages = getMessages(locale);
---

<header class="site-header">
	<div class="inner">
		<div class="brand">
			<p class="mini">{messages.mini}</p>
			<a class="brand-link" href={withBase(localePath(locale).replace(/^\/+/, ''))}>{SITE_TITLE}</a>
		</div>

		<nav class="nav-links">
			{
				NAV_LINKS.map((link) => (
					<HeaderLink
						href={withBase(
							(link.href === '/' || link.href === '/blog/'
								? localePath(locale, link.href)
								: link.href
							).replace(/^\/+/, ''),
						)}
					>
						{messages.nav[link.label.toLowerCase() as keyof typeof messages.nav] ?? link.label}
					</HeaderLink>
				))
			}
		</nav>

		<div class="auth-actions">
			<LanguageSwitcher locale={locale} pathname={Astro.url.pathname} />
			<a class="member-link" href={withBase('member/')}>{messages.readerHub}</a>
			<a class="login-link" id="auth-link" data-signed-in-label={messages.signedIn} href={withBase('login/')}>
				{messages.login}
			</a>
		</div>
	</div>
</header>

<script>
	import { getSupabaseBrowserClient } from '../lib/supabase';

	const authLink = document.querySelector<HTMLAnchorElement>('#auth-link');
	const client = getSupabaseBrowserClient();

	if (authLink && client) {
		const signedInLabel = authLink.dataset.signedInLabel ?? 'Signed In';
		const { data } = await client.auth.getSession();
		if (data.session) {
			authLink.textContent = signedInLabel;
			authLink.setAttribute('href', authLink.getAttribute('href')?.replace('/login/', '/member/') ?? '/');
		}
	}
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(14px);
		background: rgba(8, 13, 21, 0.78);
		border-bottom: 1px solid rgba(var(--line), 1);
	}

	.inner {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		width: min(1180px, calc(100% - 1.2rem));
		margin: 0 auto;
		padding: 0.9rem 0;
	}

	.brand-link {
		color: rgb(var(--ink));
		font-size: 1.2rem;
		font-weight: 800;
		text-decoration: none;
		font-family: "Sora", "Space Grotesk", "Avenir Next", sans-serif;
		letter-spacing: 0.02em;
	}

	.mini {
		margin: 0 0 0.2rem;
		color: rgb(var(--signal));
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		justify-content: center;
	}

	.nav-links :global(a) {
		padding: 0.55rem 0.9rem;
		border-radius: 999px;
		color: rgb(var(--muted));
		text-decoration: none;
	}

	.nav-links :global(a.active),
	.nav-links :global(a:hover) {
		color: rgb(var(--accent-strong));
		background: rgba(var(--accent), 0.16);
	}

	.auth-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
	}

	.member-link,
	.login-link {
		padding: 0.6rem 1rem;
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.95rem;
	}

	.member-link {
		color: rgb(var(--ink));
		background: rgba(var(--paper), 0.04);
		border: 1px solid rgba(var(--line), 1);
	}

	.login-link {
		color: rgb(var(--surface));
		background: linear-gradient(135deg, rgb(var(--accent-strong)), rgb(var(--accent)));
	}

	@media (max-width: 900px) {
		.inner {
			grid-template-columns: 1fr;
		}

		.nav-links,
		.auth-actions {
			justify-content: flex-start;
		}
	}
</style>
