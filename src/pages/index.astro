---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { HOME_FEATURES, MEMBER_BENEFITS, SITE_DESCRIPTION, SITE_LANG, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { withBase } from '../utils/paths';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const latest = posts.slice(0, 6);
const categories = Array.from(new Set(posts.map((post) => post.data.category)));
const hotTags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).slice(0, 8);
const premiumCount = posts.filter((post) => post.data.premium).length;
---

<!doctype html>
<html lang={SITE_LANG}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={featured?.data.heroImage} />
		<style>
			.home-shell {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 320px;
				gap: 1rem;
			}

			.hero-card,
			.feed-card,
			.side-card,
			.feature-card,
			.stat-card {
				background: rgb(var(--panel));
				border: 1px solid rgba(var(--line), 1);
				border-radius: 24px;
			}

			.hero-card {
				padding: 1.6rem;
				margin-bottom: 1rem;
				box-shadow: 0 20px 50px rgba(var(--accent), 0.08);
			}

			.hero-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.1rem;
			}

			.hero-card h1 {
				margin: 0.5rem 0 0.8rem;
				font-size: clamp(2.5rem, 5.5vw, 4.6rem);
				line-height: 1.06;
				max-width: 11ch;
			}

			.hero-card p {
				color: rgb(var(--muted));
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
				margin-top: 1.4rem;
			}

			.stat-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.8rem;
				margin-top: 1.4rem;
			}

			.stat-card {
				padding: 0.95rem 1rem;
				background: rgba(var(--panel-strong), 0.85);
				min-width: 0;
			}

			.stat-label {
				margin: 0 0 0.25rem;
				color: rgb(var(--muted));
				font-size: 0.82rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			.stat-value {
				margin: 0;
				font-family: Georgia, "Times New Roman", "Songti SC", serif;
				font-size: 1.8rem;
			}

			.feature-card {
				overflow: hidden;
				position: relative;
				min-height: 360px;
			}

			.feature-card img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				min-height: 360px;
				filter: saturate(0.92) contrast(1.05);
			}

			.feature-caption {
				position: absolute;
				left: 1rem;
				right: auto;
				bottom: 1rem;
				max-width: min(34rem, calc(100% - 2rem));
				padding: 0.9rem 1rem;
				border-radius: 18px;
				background: rgba(15, 19, 23, 0.68);
				color: white;
			}

			.feature-caption p {
				margin: 0;
				color: rgba(255, 255, 255, 0.8);
			}

			.section-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.8rem;
				margin: 0 0 0.9rem;
			}

			.feed-card {
				padding: 1.15rem;
			}

			.search-box {
				margin-bottom: 1rem;
			}

			.search-box input {
				width: 100%;
				padding: 0.82rem 0.95rem;
				border: 1px solid rgba(var(--line), 1);
				border-radius: 12px;
				background: rgb(var(--panel-strong));
			}

			.post-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.9rem;
			}

			.post-card {
				display: flex;
				flex-direction: column;
				height: 100%;
				padding: 0.9rem;
				border-radius: 16px;
				background: linear-gradient(180deg, rgba(var(--panel-strong), 0.9), rgba(var(--panel), 1));
				border: 1px solid rgba(var(--line), 1);
				text-decoration: none;
			}

			.post-card img {
				width: 100%;
				height: 170px;
				object-fit: cover;
				border-radius: 12px;
				margin-bottom: 0.8rem;
			}

			.post-card h3 {
				margin: 0.35rem 0 0.55rem;
				font-size: 1.18rem;
				color: rgb(var(--ink));
			}

			.post-card p {
				margin: 0;
				color: rgb(var(--muted));
				font-size: 0.95rem;
			}

			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 0.8rem;
				color: rgb(var(--muted));
				font-size: 0.84rem;
			}

			.tag-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				margin-top: 0.8rem;
			}

			.tag {
				padding: 0.22rem 0.62rem;
				border-radius: 999px;
				background: rgba(var(--accent), 0.08);
				color: rgb(var(--accent));
				font-size: 0.84rem;
			}

			.side-column {
				display: grid;
				gap: 1rem;
				align-self: start;
			}

			.side-card {
				padding: 1.1rem;
				background: rgba(var(--panel), 0.94);
			}

			.side-card ul {
				margin: 0;
				padding-left: 1rem;
			}

			.side-card li + li {
				margin-top: 0.55rem;
			}

			.category-list,
			.tag-cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 0.8rem;
			}

			.category-pill,
			.tag-cloud a {
				padding: 0.45rem 0.72rem;
				border-radius: 999px;
				background: rgb(var(--panel-strong));
				border: 1px solid rgba(var(--line), 1);
				color: rgb(var(--muted));
				text-decoration: none;
				font-size: 0.9rem;
			}

			@media (max-width: 980px) {
				.home-shell,
				.hero-grid,
				.post-list,
				.stat-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="home-shell">
				<div>
					<section class="hero-card">
						<p class="eyebrow">Independent AI Desk</p>
						<div class="hero-grid">
							<div>
								<h1>{SITE_TITLE}</h1>
								<p>{SITE_DESCRIPTION}</p>
								<p>{SITE_TAGLINE}</p>
								<div class="hero-actions">
									<a class="button" href={withBase('blog/')}>Open the briefs</a>
									<a class="button button-soft" href={withBase('vip/')}>View membership</a>
									<a class="button button-soft" href={withBase('login/')}>Reader login</a>
								</div>
								<div class="stat-grid">
									<div class="stat-card">
										<p class="stat-label">Published</p>
										<p class="stat-value">{posts.length}</p>
									</div>
									<div class="stat-card">
										<p class="stat-label">Tracks</p>
										<p class="stat-value">{categories.length}</p>
									</div>
									<div class="stat-card">
										<p class="stat-label">Premium</p>
										<p class="stat-value">{premiumCount}</p>
									</div>
								</div>
							</div>
							<a class="feature-card" href={featured ? withBase(`blog/${featured.id}/`) : withBase('blog/')}>
								{featured?.data.heroImage && <img src={featured.data.heroImage.src} alt={featured.data.title} />}
								{featured && (
									<div class="feature-caption">
										<strong>{featured.data.title}</strong>
										<p>{featured.data.description}</p>
									</div>
								)}
							</a>
						</div>
					</section>

					<section class="feed-card">
						<div class="section-head">
							<div>
								<p class="eyebrow">Daily Signal Feed</p>
								<h2>Today&apos;s signal feed</h2>
							</div>
							<a href={withBase('blog/')}>Browse all briefs</a>
						</div>

						<div class="search-box">
							<input id="post-search" type="search" placeholder="Search models, companies, products, or topics" />
						</div>

						<div class="post-list" id="post-list">
							{
								latest.map((post) => (
									<a
										class="post-card"
										href={withBase(`blog/${post.id}/`)}
										data-search={`${post.data.title} ${post.data.category} ${post.data.tags.join(' ')}`}
									>
										{post.data.heroImage && <img src={post.data.heroImage.src} alt={post.data.title} />}
										<div class="meta-row">
											<span>{post.data.category}</span>
											<span><FormattedDate date={post.data.pubDate} /></span>
											{post.data.premium && <span>Subscriber Preview</span>}
										</div>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
										<div class="tag-row">
											{post.data.tags.slice(0, 3).map((tag) => <span class="tag">#{tag}</span>)}
										</div>
									</a>
								))
							}
						</div>
					</section>
				</div>

				<aside class="side-column">
					<section class="side-card">
						<p class="eyebrow">Readers Club</p>
						<h3>Turn the site into a real reader product</h3>
						<p>The login layer is already live. From here, it can grow into email briefings, premium notes, saved reads, and a proper subscriber experience.</p>
						<div class="hero-actions">
							<a class="button" href={withBase('login/')}>Enter reader hub</a>
						</div>
					</section>

					<section class="side-card">
						<p class="eyebrow">Editorial Spine</p>
						<h3>Editorial spine</h3>
						<ul>
							{HOME_FEATURES.map((item) => <li><strong>{item.title}</strong>: {item.description}</li>)}
						</ul>
					</section>

					<section class="side-card">
						<p class="eyebrow">Subscription</p>
						<h3>What members get</h3>
						<ul>
							{MEMBER_BENEFITS.map((item) => <li>{item}</li>)}
						</ul>
					</section>

					<section class="side-card">
						<p class="eyebrow">Coverage</p>
						<h3>Coverage map</h3>
						<div class="category-list">
							{categories.map((category) => <span class="category-pill">{category}</span>)}
						</div>
					</section>

					<section class="side-card">
						<p class="eyebrow">Signal Tags</p>
						<h3>Recurring topics</h3>
						<div class="tag-cloud">
							{hotTags.map((tag) => <a href={withBase('blog/')}>#{tag}</a>)}
						</div>
					</section>
				</aside>
			</div>
		</main>
		<Footer />

		<script>
			const input = document.querySelector<HTMLInputElement>('#post-search');
			const cards = Array.from(document.querySelectorAll<HTMLElement>('#post-list .post-card'));

			if (input) {
				input.addEventListener('input', () => {
					const keyword = input.value.trim().toLowerCase();

					cards.forEach((card) => {
						const haystack = card.dataset.search?.toLowerCase() ?? '';
						card.style.display = keyword === '' || haystack.includes(keyword) ? '' : 'none';
					});
				});
			}
		</script>
	</body>
</html>
