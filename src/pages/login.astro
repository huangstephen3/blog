---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_LANG, SITE_TITLE } from '../consts';
import { withBase } from '../utils/paths';
---

<!doctype html>
<html lang={SITE_LANG}>
	<head>
		<BaseHead title={`Log In | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.auth-wrap {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 340px;
				gap: 1rem;
			}

			.panel {
				padding: 1.3rem;
				border-radius: 20px;
				background: rgb(var(--panel));
				border: 1px solid rgba(var(--line), 1);
			}

			form {
				display: grid;
				gap: 0.85rem;
				margin-top: 1rem;
			}

			label {
				display: grid;
				gap: 0.35rem;
				font-weight: 600;
			}

			input {
				padding: 0.85rem 0.95rem;
				border: 1px solid rgba(var(--line), 1);
				border-radius: 12px;
				background: rgb(var(--panel-strong));
			}

			.status {
				min-height: 1.5rem;
				color: rgb(var(--muted));
			}

			.help-list {
				margin: 0;
				padding-left: 1rem;
			}

			.help-list li + li {
				margin-top: 0.6rem;
			}

			@media (max-width: 900px) {
				.auth-wrap {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title">
				<p class="eyebrow">Readers Login</p>
				<h1>Enter the reader layer.</h1>
				<p>Type your email and the site will send a Magic Link. Open the email, click once, and you will land in the member area.</p>
			</div>

			<div class="auth-wrap">
				<section class="panel" id="login-panel" data-member-redirect={withBase('member/')}>
					<h2>Email-based access</h2>
					<p>This flow stays intentionally light: no password wall, less friction, and a cleaner path into future daily briefs and subscriber-only notes.</p>
					<form id="login-form">
						<label>
							Email address
							<input id="email" type="email" placeholder="name@example.com" required />
						</label>
						<button class="button" type="submit">Send Magic Link</button>
					</form>
					<p class="status" id="status"></p>
				</section>

				<aside class="panel">
					<h2>Why start with Magic Link</h2>
					<ul class="help-list">
						<li>Lower friction for new readers.</li>
						<li>Less maintenance overhead in the early stage.</li>
						<li>A faster path to a working subscription funnel.</li>
						<li>Easy to expand later into richer account permissions.</li>
					</ul>
				</aside>
			</div>
		</main>
		<Footer />

		<script>
			import { getSupabaseBrowserClient } from '../lib/supabase';

			const panel = document.querySelector<HTMLElement>('#login-panel');
			const form = document.querySelector<HTMLFormElement>('#login-form');
			const emailInput = document.querySelector<HTMLInputElement>('#email');
			const status = document.querySelector<HTMLElement>('#status');
			const memberRedirect = panel?.dataset.memberRedirect ?? '/member/';
			const memberUrl = `${window.location.origin}${memberRedirect}`;
			const client = getSupabaseBrowserClient();

			if (client) {
				const { data } = await client.auth.getSession();
				if (data.session) {
					window.location.href = memberRedirect;
				}
			}

			form?.addEventListener('submit', async (event) => {
				event.preventDefault();

				if (!client) {
					if (status) status.textContent = 'Supabase environment variables are missing, so Magic Link is currently unavailable.';
					return;
				}

				const email = emailInput?.value.trim() ?? '';
				if (!email) {
					if (status) status.textContent = 'Please enter your email first.';
					return;
				}

				if (status) status.textContent = 'Sending Magic Link...';

				const { error } = await client.auth.signInWithOtp({
					email,
					options: {
						emailRedirectTo: memberUrl,
					},
				});

				if (status) {
					status.textContent = error
						? `Send failed: ${error.message}`
						: 'Email sent. Open your inbox and click the login link.';
				}
			});
		</script>
	</body>
</html>
