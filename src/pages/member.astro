---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_LANG, SITE_TITLE } from '../consts';
import { withBase } from '../utils/paths';
---

<!doctype html>
<html lang={SITE_LANG}>
	<head>
		<BaseHead title={`Member Area | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.member-grid {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 320px;
				gap: 1rem;
			}

			.panel {
				padding: 1.2rem;
				border-radius: 20px;
				background: rgb(var(--panel));
				border: 1px solid rgba(var(--line), 1);
			}

			.hidden {
				display: none;
			}

			.info {
				color: rgb(var(--muted));
			}

			@media (max-width: 900px) {
				.member-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title">
				<p class="eyebrow">Readers Room</p>
				<h1>Your reader workspace.</h1>
				<p>This is the member entry point for daily briefs, saved reads, premium notes, and future subscription products.</p>
			</div>

			<div id="member-loading" class="panel" data-login-redirect={withBase('login/')}>Checking your session...</div>

			<div id="member-app" class="member-grid hidden">
				<section class="panel">
					<p class="eyebrow">Reader Session</p>
					<h2>Welcome back</h2>
					<p class="info">Signed in as: <strong id="member-email">-</strong></p>
					<p class="info">This area can expand into:</p>
					<ul>
						<li>A members-only morning brief</li>
						<li>Saved story lists and topic collections</li>
						<li>Premium columns and account settings</li>
					</ul>
					<p style="margin-top: 1rem;">
						<button class="button" id="logout-button" type="button">Log Out</button>
					</p>
				</section>

				<aside class="panel">
					<p class="eyebrow">Next Phase</p>
					<h2>Highest-value next steps</h2>
					<ul>
						<li>Archive daily briefs by date and topic</li>
						<li>Open deeper analysis to subscribers</li>
						<li>Gate content by membership tier</li>
					</ul>
				</aside>
			</div>
		</main>
		<Footer />

		<script>
			import { getSupabaseBrowserClient } from '../lib/supabase';

			const loading = document.querySelector<HTMLElement>('#member-loading');
			const app = document.querySelector<HTMLElement>('#member-app');
			const email = document.querySelector<HTMLElement>('#member-email');
			const logoutButton = document.querySelector<HTMLButtonElement>('#logout-button');
			const loginUrl = loading?.dataset.loginRedirect ?? '/login/';
			const client = getSupabaseBrowserClient();

			if (!client) {
				if (loading) loading.textContent = 'Supabase environment variables are missing, so the member area is unavailable.';
			} else {
				const { data } = await client.auth.getSession();
				const session = data.session;

				if (!session) {
					window.location.href = loginUrl;
				} else {
					if (email) email.textContent = session.user.email ?? '-';
					loading?.classList.add('hidden');
					app?.classList.remove('hidden');
				}

				logoutButton?.addEventListener('click', async () => {
					await client.auth.signOut();
					window.location.href = loginUrl;
				});
			}
		</script>
	</body>
</html>
