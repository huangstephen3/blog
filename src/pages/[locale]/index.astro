---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { HOME_FEATURES, MEMBER_BENEFITS, NEWS_SECTIONS, SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../../consts';
import { DEFAULT_LOCALE, LOCALES, getLocale, getMessages, isLocale, localePath } from '../../lib/i18n';
import { withBase } from '../../utils/paths';

export function getStaticPaths() {
	return LOCALES.filter((locale) => locale.code !== DEFAULT_LOCALE).map((locale) => ({
		params: { locale: locale.code },
	}));
}

const locale = isLocale(Astro.params.locale ?? '') ? Astro.params.locale! : DEFAULT_LOCALE;
const localeMeta = getLocale(locale);
const messages = getMessages(locale);
const posts = (await getCollection('blog', ({ data }) => !data.draft && (data.locale ?? 'en') === locale)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const latest = posts.slice(0, 6);
const hotTags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).slice(0, 8);
const premiumCount = posts.filter((post) => post.data.premium).length;
const hrefFor = (path = '') => withBase(localePath(locale, path).replace(/^\/+/, ''));
---

<!doctype html>
<html lang={localeMeta.lang}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={featured?.data.heroImage} />
		<style>
			.home-shell { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 1rem; }
			.hero-card, .feed-card, .side-card, .feature-card, .stat-card { background: rgb(var(--panel)); border: 1px solid rgba(var(--line), 1); border-radius: 24px; }
			.hero-card { padding: 1.6rem; margin-bottom: 1rem; box-shadow: 0 20px 50px rgba(var(--accent), 0.08); }
			.hero-grid { display: grid; grid-template-columns: 1fr; gap: 1.1rem; }
			.hero-card h1 { margin: 0.5rem 0 0.8rem; font-size: clamp(1.9rem, 5vw, 3rem); line-height: 1.02; max-width: 8ch; }
			.hero-card p { color: rgb(var(--muted)); }
			.hero-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.4rem; }
			.stat-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.8rem; margin-top: 1.4rem; }
			.stat-card { padding: 0.95rem 1rem; background: rgba(var(--panel-strong), 0.85); min-width: 0; }
			.stat-label { margin: 0 0 0.25rem; color: rgb(var(--muted)); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.08em; }
			.stat-value { margin: 0; font-family: "Sora", "Space Grotesk", "Avenir Next", sans-serif; font-size: 1.6rem; }
			.feature-card { display: grid; gap: 1rem; padding: 1rem; text-decoration: none; }
			.feature-card img { display: block; width: 100%; height: clamp(220px, 32vw, 360px); object-fit: cover; border-radius: 18px; filter: saturate(0.92) contrast(1.05); }
			.feature-caption { max-width: 44rem; color: rgb(var(--ink)); }
			.feature-caption strong { display: block; margin-bottom: 0.45rem; font-size: clamp(1.2rem, 2vw, 1.7rem); line-height: 1.15; }
			.feature-caption p { margin: 0; color: rgb(var(--muted)); }
			.section-head { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; margin: 0 0 0.9rem; }
			.feed-card { padding: 1.15rem; }
			.search-box { margin-bottom: 1rem; }
			.search-box input { width: 100%; padding: 0.82rem 0.95rem; border: 1px solid rgba(var(--line), 1); border-radius: 12px; background: rgb(var(--panel-strong)); }
			.post-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.9rem; }
			.post-card { display: flex; flex-direction: column; height: 100%; padding: 0.9rem; border-radius: 16px; background: linear-gradient(180deg, rgba(var(--panel-strong), 0.9), rgba(var(--panel), 1)); border: 1px solid rgba(var(--line), 1); text-decoration: none; }
			.post-card img { width: 100%; height: 170px; object-fit: cover; border-radius: 12px; margin-bottom: 0.8rem; }
			.post-card h3 { margin: 0.35rem 0 0.55rem; font-size: 1rem; color: rgb(var(--ink)); }
			.post-card p { margin: 0; color: rgb(var(--muted)); font-size: 0.95rem; }
			.meta-row { display: flex; flex-wrap: wrap; gap: 0.5rem 0.8rem; color: rgb(var(--muted)); font-size: 0.84rem; }
			.tag-row, .category-list, .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 0.8rem; }
			.tag, .category-pill, .tag-cloud a { padding: 0.22rem 0.62rem; border-radius: 999px; background: rgba(var(--accent), 0.08); color: rgb(var(--accent)); font-size: 0.84rem; text-decoration: none; border: 1px solid rgba(var(--line), 1); }
			.side-column { display: grid; gap: 1rem; align-self: start; }
			.side-card { padding: 1.1rem; background: rgba(var(--panel), 0.94); }
			.side-card ul { margin: 0; padding-left: 1rem; }
			.side-card li + li { margin-top: 0.55rem; }
			@media (max-width: 980px) { .home-shell, .hero-grid, .post-list, .stat-grid { grid-template-columns: 1fr; } }
		</style>
	</head>
	<body>
		<Header locale={locale} />
		<main>
			<div class="home-shell">
				<div>
					<section class="hero-card">
						<p class="eyebrow">{messages.mini}</p>
						<div class="hero-grid">
							<div>
								<h1>{SITE_TITLE}</h1>
								<p>{SITE_DESCRIPTION}</p>
								<p>{SITE_TAGLINE}</p>
								<div class="hero-actions">
									<a class="button" href={hrefFor('/blog/')}>{messages.browseBriefs}</a>
									<a class="button button-soft" href={withBase('vip/')}>{messages.nav.membership}</a>
									<a class="button button-soft" href={withBase('login/')}>{messages.login}</a>
								</div>
								<div class="stat-grid">
									<div class="stat-card"><p class="stat-label">{messages.publishedCount}</p><p class="stat-value">{posts.length}</p></div>
									<div class="stat-card"><p class="stat-label">{messages.tracksCount}</p><p class="stat-value">{NEWS_SECTIONS.length}</p></div>
									<div class="stat-card"><p class="stat-label">{messages.premiumCount}</p><p class="stat-value">{premiumCount}</p></div>
								</div>
							</div>
							{featured && (
								<a class="feature-card" href={hrefFor(`/blog/${featured.data.baseSlug ?? featured.id}/`)}>
									{featured.data.heroImage && <img src={featured.data.heroImage.src} alt={featured.data.title} />}
									<div class="feature-caption">
										<p class="eyebrow">{messages.featuredBrief}</p>
										<strong>{featured.data.title}</strong>
										<p>{featured.data.description}</p>
									</div>
								</a>
							)}
						</div>
					</section>

					<section class="feed-card">
						<div class="section-head">
							<div>
								<p class="eyebrow">{messages.dailySignalFeed}</p>
								<h2>{messages.todaySignal}</h2>
							</div>
							<a href={hrefFor('/blog/')}>{messages.browseBriefs}</a>
						</div>
						<div class="search-box">
							<input id="post-search" type="search" placeholder={messages.searchPlaceholder} />
						</div>
						<div class="post-list" id="post-list">
							{
								latest.map((post) => (
									<a class="post-card" href={hrefFor(`/blog/${post.data.baseSlug ?? post.id}/`)} data-search={`${post.data.title} ${post.data.category} ${post.data.tags.join(' ')}`}>
										{post.data.heroImage && <img src={post.data.heroImage.src} alt={post.data.title} />}
										<div class="meta-row">
											<span>{post.data.category}</span>
											<span><FormattedDate date={post.data.pubDate} locale={localeMeta.lang} /></span>
											{post.data.premium && <span>{messages.subscriberPreview}</span>}
										</div>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
										<div class="tag-row">{post.data.tags.slice(0, 3).map((tag) => <span class="tag">#{tag}</span>)}</div>
									</a>
								))
							}
						</div>
					</section>
				</div>

				<aside class="side-column">
					<section class="side-card">
						<p class="eyebrow">{messages.readersClubLabel}</p>
						<h3>{messages.readersClub}</h3>
						<p>{messages.readersClubCopy}</p>
						<div class="hero-actions"><a class="button" href={withBase('login/')}>{messages.enterReaderHub}</a></div>
					</section>
					<section class="side-card">
						<p class="eyebrow">{messages.editorialSpineLabel}</p>
						<h3>{messages.editorialSpine}</h3>
						<ul>{HOME_FEATURES.map((item) => <li><strong>{item.title}</strong>: {item.description}</li>)}</ul>
					</section>
					<section class="side-card">
						<p class="eyebrow">{messages.subscriptionLabel}</p>
						<h3>{messages.memberBenefits}</h3>
						<ul>{MEMBER_BENEFITS.map((item) => <li>{item}</li>)}</ul>
					</section>
					<section class="side-card">
						<p class="eyebrow">{messages.coverageLabel}</p>
						<h3>{messages.coverageMap}</h3>
						<div class="category-list">{NEWS_SECTIONS.map((section) => <span class="category-pill">{section.title}</span>)}</div>
					</section>
					<section class="side-card">
						<p class="eyebrow">{messages.signalTagsLabel}</p>
						<h3>{messages.recurringTopics}</h3>
						<div class="tag-cloud">{hotTags.map((tag) => <a href={hrefFor('/blog/')}>#{tag}</a>)}</div>
					</section>
				</aside>
			</div>
		</main>
		<Footer locale={locale} />

		<script>
			const input = document.querySelector<HTMLInputElement>('#post-search');
			const cards = Array.from(document.querySelectorAll<HTMLElement>('#post-list .post-card'));
			if (input) {
				input.addEventListener('input', () => {
					const keyword = input.value.trim().toLowerCase();
					cards.forEach((card) => {
						const haystack = card.dataset.search?.toLowerCase() ?? '';
						card.style.display = keyword === '' || haystack.includes(keyword) ? '' : 'none';
					});
				});
			}
		</script>
	</body>
</html>
