---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { MEMBER_BENEFITS, SITE_DESCRIPTION, SITE_LANG, SITE_TITLE } from '../consts';
import { withBase } from '../utils/paths';
---

<!doctype html>
<html lang={SITE_LANG}>
	<head>
		<BaseHead title={`Membership | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.vip-grid {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 330px;
				gap: 1rem;
			}

			.panel,
			.price-card {
				padding: 1.2rem;
				border-radius: 20px;
				background: rgb(var(--panel));
				border: 1px solid rgba(var(--line), 1);
			}

			.benefits {
				margin: 0;
				padding-left: 1rem;
			}

			.benefits li + li {
				margin-top: 0.6rem;
			}

			.price {
				margin: 0.5rem 0;
				font-size: 2.4rem;
				font-weight: 800;
			}

			.note {
				color: rgb(var(--muted));
			}

			@media (max-width: 900px) {
				.vip-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title">
				<p class="eyebrow">Subscription</p>
				<h1>Membership starts with better signal.</h1>
				<p>This is the launch point for a tighter editorial product: faster daily briefs, deeper analysis, and a cleaner reader relationship.</p>
			</div>

			<div class="vip-grid">
				<section class="panel">
					<p class="eyebrow">Why Subscribe</p>
					<h2>What readers get first</h2>
					<p>
						The first job is not feature bloat. It is building a dependable editorial engine around one real AI story
						each day, sharper product tracking, and clean topic-based analysis that saves readers time.
					</p>
					<ul class="benefits">
						{MEMBER_BENEFITS.map((item) => <li>{item}</li>)}
					</ul>
				</section>

				<aside class="price-card">
					<p class="eyebrow">Phase One</p>
					<h2>Build the content engine first</h2>
					<p class="price">Daily Brief</p>
					<p class="note">The smartest first move is consistent editorial output. Monetization and tiering should come after the habit of publishing is strong.</p>
					<p class="note">Later layers can add:</p>
					<ul class="benefits">
						<li>Email briefings</li>
						<li>Premium columns</li>
						<li>Research archives and topic pages</li>
						<li>Paid memberships and comments</li>
					</ul>
					<p style="margin-top: 1rem;">
						<a class="button" href={withBase('login/')}>Join the reader layer</a>
					</p>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>
