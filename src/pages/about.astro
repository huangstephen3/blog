---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_LANG, SITE_TITLE, STARTER_STEPS } from '../consts';
---

<!doctype html>
<html lang={SITE_LANG}>
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.about-grid {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 320px;
				gap: 1rem;
			}

			.panel {
				padding: 1.2rem;
				border-radius: 20px;
				background: rgb(var(--panel));
				border: 1px solid rgba(var(--line), 1);
			}

			.step-list {
				margin: 0;
				padding-left: 1.2rem;
			}

			.step-list li + li {
				margin-top: 0.7rem;
			}

			@media (max-width: 900px) {
				.about-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-grid">
				<section class="panel">
					<p class="eyebrow">About The Desk</p>
					<h1>An independent AI newsroom built for signal, not noise.</h1>
					<p>
						Signal Layer is no longer a generic blog shell. It is an editorial product focused on model releases,
						platform updates, infrastructure spending, developer tools, policy moves, and the companies reshaping
						the AI stack.
					</p>
					<p>
						The stack stays intentionally light so the work stays centered on reporting and editorial judgment.
						The site already has public hosting, automatic deployment, RSS, and reader login wired in. The real
						advantage now comes from publishing consistently.
					</p>
					<p>
						If you want to grow this into a fuller media product, the next layer can add premium newsletters,
						private archives, thematic landing pages, reader comments, and paid memberships without changing the
						core publishing flow.
					</p>
				</section>

				<aside class="panel">
					<p class="eyebrow">Editorial Loop</p>
					<h2>What matters next</h2>
					<ol class="step-list">
						{STARTER_STEPS.map((step) => <li>{step}</li>)}
					</ol>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>
